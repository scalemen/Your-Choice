# StudyGenius Environment Configuration
# Copy from .env.example and customize for your setup

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5000
HOST=localhost

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database Connection
DATABASE_URL=postgresql://postgres@localhost:5432/studygenius

# Database Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# =============================================================================
# SESSION & SECURITY
# =============================================================================
# Generate a secure random string for JWT secret
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this-too

# CORS Settings
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# =============================================================================
# EXTERNAL SERVICES (Optional - for full functionality)
# =============================================================================

# OpenAI API (for AI features)
# OPENAI_API_KEY=your-openai-api-key-here

# Google OAuth (for social login)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Enable detailed logging in development
DEBUG=true
LOG_LEVEL=debug

# Development database (optional override)
# DATABASE_URL_DEV=postgresql://postgres@localhost:5432/studygenius_dev

# =============================================================================
# FILE STORAGE
# =============================================================================
# Upload directory for user files
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt,md

# =============================================================================
# REDIS (Optional - for caching and sessions)
# =============================================================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# =============================================================================
# LOCALE & INTERNATIONALIZATION
# =============================================================================
DEFAULT_LOCALE=en_US.UTF-8
DEFAULT_TIMEZONE=UTC
DEFAULT_LANGUAGE=en