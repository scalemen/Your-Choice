# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/studygenius
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studygenius
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server Configuration
NODE_ENV=development
PORT=3000
JWT_SECRET=your_jwt_secret_here_change_in_production

# Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=2147483648  # 2GB in bytes
MAX_VIDEO_SIZE=2147483648  # 2GB for videos

# Redis Configuration (if using Redis for caching)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Security
CORS_ORIGIN=http://localhost:5173
SESSION_SECRET=your_session_secret_here

# External Services
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Feature Flags
ENABLE_VIDEO_PROCESSING=true
ENABLE_RECOMMENDATION_ENGINE=true
ENABLE_REAL_TIME_FEATURES=true
ENABLE_ANALYTICS=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Social Media Features
ENABLE_SOCIAL_MEDIA=true
MAX_POST_LENGTH=2200
MAX_STORY_DURATION=300  # 5 minutes in seconds

# Video Platform Features
ENABLE_VIDEO_PLATFORM=true
MAX_VIDEO_DURATION=7200  # 2 hours in seconds
SUPPORTED_VIDEO_FORMATS=mp4,webm,mov,avi
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp